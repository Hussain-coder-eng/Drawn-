{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." }
      },
      "required": ["uid", "email"]
    },
    "Route": {
      "title": "Saved Route",
      "description": "A GPS art route designed by a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner of the route." },
        "label": { "type": "string", "description": "User-provided name for the route." },
        "mode": { "type": "string", "enum": ["shapes", "text", "draw"] },
        "selectedShape": { "type": "string" },
        "textInput": { "type": "string" },
        "fontStyle": { "type": "string" },
        "distance": { "type": "number" },
        "unit": { "type": "string", "enum": ["mi", "km"] },
        "location": { "type": "string" },
        "surface": { "type": "string", "enum": ["roads", "trails", "mixed"] },
        "routeFidelity": { "type": "number" },
        "timestamp": { "type": "number", "description": "Creation time in milliseconds." },
        "idealCoords": { "type": "array", "items": { "type": "object" } },
        "snappedCoords": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["uid", "label", "mode", "distance", "timestamp"]
    },
    "RateLimit": {
      "title": "Rate Limit",
      "description": "Tracks user generation requests.",
      "type": "object",
      "properties": {
        "generations": { "type": "array", "items": { "type": "string", "format": "date-time" } }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/routes/{routeId}": {
      "schema": "Route",
      "description": "Collection of all saved routes."
    },
    "/rateLimits/{userId}": {
      "schema": "RateLimit",
      "description": "User rate limit tracking."
    }
  }
}
